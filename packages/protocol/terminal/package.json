{
  "name": "dark-x402-terminal",
  "version": "1.0.0",
  "description": "Dark X402 Terminal - Privacy-First DeFi Terminal with AI Agents",
  "type": "commonjs",
  "main": "dist/terminal/index.js",
  "bin": {
    "dark-x402": "./dist/terminal/index.js",
    "dx402": "./dist/terminal/index.js"
  },
  "scripts": {
    "start": "node dist/terminal/index.js",
    "dev": "ts-node --transpile-only --prefer-ts-exts index.ts",
    "build": "tsc",
    "watch": "tsc --watch",
    "clean": "rm -rf dist",
    "terminal": "npm run dev",
    "dashboard": "npm run build && node dist/terminal/x402-token-dashboard.js",
    "x402": "npm run dashboard"
  },
  "keywords": [
    "defi",
    "privacy",
    "solana",
    "terminal",
    "ai",
    "agents",
    "dark-protocol",
    "x402"
  ],
  "author": "Dark Protocol",
  "license": "Apache-2.0",
  "dependencies": {
    "@coral-xyz/anchor": "^0.32.1",
    "@google/generative-ai": "^0.21.0",
    "@noble/ciphers": "^2.0.1",
    "@noble/hashes": "^2.0.1",
    "@solana/web3.js": "^1.98.4",
    "@types/ws": "^8.18.1",
    "axios": "^1.13.2",
    "bip32": "^5.0.0",
    "bip39": "^3.1.0",
    "bs58": "^6.0.0",
    "chalk": "^4.1.2",
    "cli-table3": "^0.6.5",
    "dotenv": "^16.4.5",
    "figlet": "^1.7.0",
    "helius-sdk": "^2.0.2",
    "inquirer": "^8.2.6",
    "ora": "^5.4.1",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0",
    "tiny-secp256k1": "^2.2.4",
    "tweetnacl": "^1.0.3",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@types/figlet": "^1.5.8",
    "@types/inquirer": "^8.2.10",
    "@types/node": "^20.0.0",
    "@types/qrcode": "^1.5.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
