# Dark X402 Terminal Configuration

# Required: Helius RPC API Key
# Get your free API key at https://helius.dev
HELIUS_API_KEY=your_helius_api_key_here

# Optional: Jupiter Swap API Key
# For private swaps - get at https://station.jup.ag/api-keys
JUPITER_API_KEY=your_jupiter_api_key_here

# Optional: RedPill AI API Key
# For AI agent TEE verification - get at https://redpill.ai
REDPILL_API_KEY=your_redpill_api_key_here

# Optional: Google AI API Key
# For Google Gen AI agents - get at https://makersuite.google.com/app/apikey
GOOGLE_AI_API_KEY=your_google_ai_api_key_here

# Optional: Network selection
# Options: devnet, mainnet, testnet, localnet
NETWORK=devnet

# Optional: Custom RPC URL
# Leave empty to use Helius automatic endpoints
# HELIUS_RPC_URL=https://custom-rpc-url.com
