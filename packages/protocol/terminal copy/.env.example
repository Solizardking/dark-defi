# Dark X402 Terminal Configuration
# Copy this file to .env and fill in your real keys
# NEVER commit .env to git — it's in .gitignore

# ──────────────────────────────────────────────────────────────
# Required: Helius RPC API Key
# Get your free API key at https://helius.dev
# ──────────────────────────────────────────────────────────────
HELIUS_API_KEY=your_helius_api_key_here

# ──────────────────────────────────────────────────────────────
# AI Providers (at least one recommended for chat)
# Priority order: Google AI → XAI → RedPill → local fallback
# ──────────────────────────────────────────────────────────────

# Google Gemini — https://makersuite.google.com/app/apikey
GOOGLE_AI_API_KEY=your_google_ai_api_key_here

# XAI Grok — https://x.ai
XAI_API_KEY=your_xai_api_key_here

# RedPill Privacy-First AI Gateway — https://redpill.ai
# OpenAI-compatible, routes through TEE-protected gateway
REDPILL_API_KEY=your_redpill_api_key_here

# RedPill model selection (default: anthropic/claude-sonnet-4.5)
# For GPU TEE confidential inference, use one of:
#   phala/qwen3.5-27b   — Phala Network TEE
#   z-ai/glm-5.1        — Chutes GPU TEE
#   z-ai/glm-5          — Near AI GPU TEE
#   openai/gpt-5        — Standard GPT-5
#   anthropic/claude-sonnet-4.5 — Claude Sonnet (default)
REDPILL_MODEL=anthropic/claude-sonnet-4.5

# Set to 1 to auto-select a GPU TEE model (phala/qwen3.5-27b)
# REDPILL_TEE=1

# ──────────────────────────────────────────────────────────────
# Optional: Jupiter Swap API Key
# For private swaps - get at https://station.jup.ag/api-keys
# ──────────────────────────────────────────────────────────────
JUPITER_API_KEY=your_jupiter_api_key_here

# ──────────────────────────────────────────────────────────────
# Optional: Birdeye API Key
# For CLAWD token dashboard real-time data — https://birdeye.so
# ──────────────────────────────────────────────────────────────
BIRDEYE_API_KEY=your_birdeye_api_key_here

# ──────────────────────────────────────────────────────────────
# Phoenix Perps (Vulcan CLI)
# Install: curl -sSf https://cli.phoenix.trade/install.sh | sh
# Default location: ~/.local/bin/vulcan
# Override if installed elsewhere:
# ──────────────────────────────────────────────────────────────
# VULCAN_BIN=/Users/you/.local/bin/vulcan

# ──────────────────────────────────────────────────────────────
# Network & RPC
# ──────────────────────────────────────────────────────────────
NETWORK=devnet

# Optional: Custom RPC URL (leave empty to use Helius automatic endpoints)
HELIUS_RPC_URL=

# Local server port (default: 3333)
LOCAL_PORT=3333
